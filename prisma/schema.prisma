generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id               String     @id
  email            String     @unique
  firstName        String
  lastName         String
  university       String
  department       String?
  grade            String
  targetUniversity String?
  targetDepartment String?
  interests        String[]
  careerPath       String
  phone            String?
  address          String?
  purchases        Purchase[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model University {
  id        String    @id @default(cuid())
  name      String    @unique
  tags      String[]
  level     String?
  area      String?
  faculties Faculty[]
  labs      Lab[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Faculty {
  id           String       @id @default(cuid())
  name         String
  universityId String
  university   University   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  departments  Department[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([universityId, name])
}

model Department {
  id        String   @id @default(cuid())
  name      String
  theme     String?
  facultyId String
  faculty   Faculty  @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  exams     Exam[]
  labs      Lab[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([facultyId, name])
}

model Exam {
  id          String      @id @default(cuid())
  title       String
  price       Int
  category    String
  image       String?
  description String?
  author      String?
  contents    String[]
  preview     String?
  deptId      String?
  department  Department? @relation(fields: [deptId], references: [id], onDelete: SetNull)
  purchases   Purchase[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Purchase {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  stripeId  String?
  createdAt DateTime @default(now())
}

model Lab {
  id             String      @id @default(cuid())
  universityId   String?
  university     University? @relation(fields: [universityId], references: [id])
  universityName String?
  name           String
  tags           String[]
  heroImage      String
  website        String?
  about          String?
  profName       String?
  profImage      String?
  message        String?
  contact        Json?
  papers         Json?
  stats          Json?
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}
