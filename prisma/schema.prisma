// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id               String   @id // Clerk User ID
  email            String   @unique
  firstName        String
  lastName         String
  university       String   // 現在の大学
  department       String?  // 現在の学部・学科
  grade           String   // 学年
  targetUniversity String?  // 志望大学院
  targetDepartment String?  // 志望専攻
  interests       String[] // 興味のある分野（タグ）
  careerPath      String   // 希望するキャリアパス
  phone           String?
  address         String?
  purchases       Purchase[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  price       Int
  category    String   // past-exam, practice, forecast, etc.
  image       String
  description String?
  author      String?
  contents    String[]
  preview     String?
  deptId      String?  // 関連する学科ID
  purchases   Purchase[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Purchase {
  id        String   @id @default(cuid())
  profileId String   // Clerk User ID
  profile   Profile  @relation(fields: [profileId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  stripeId  String?  // Stripe Session ID or Payment Intent ID
  createdAt DateTime @default(now())
}

model University {
  id          String   @id @default(cuid())
  name        String
  tags        String[] // 国立, 私立, 偏差値帯 etc.
  level       String   // A, B, C etc.
  area        String   // 東京, 大阪 etc.
  departments Department[]
  labs        Lab[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id           String     @id @default(cuid())
  name         String
  theme        String     // 研究テーマ
  universityId String
  university   University @relation(fields: [universityId], references: [id])
  labs         Lab[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Lab {
  id              String     @id @default(cuid())
  universityId    String?
  university      University? @relation(fields: [universityId], references: [id])
  universityName  String?    // 冗長だが検索・一覧用に保持
  name            String
  tags            String[]
  heroImage       String
  website         String?
  about           String?
  profName        String?
  profImage       String?
  message         String?
  contact         Json?      // { prof: string, assistant: string }
  papers          Json?      // list of { title: string, summary: string, link: string }
  stats           Json?      // { gender: number, international: number, working: number }
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}
