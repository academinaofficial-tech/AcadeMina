generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id               String     @id
  email            String     @unique
  firstName        String
  lastName         String
  university       String
  faculty          String?    // 👈 新規追加: 現在の学部（1意選択なのでString?）
  department       String?
  grade            String

  // ▼ 既存の志望校データ（過去のデータを消さないためにそのまま残します）
  targetUniversity String?
  targetDepartment String?

  // ▼ 新規追加: 複数選択の志望校データ
  targetSchools    Json?      // 👈 新規追加: 大学・学部・専攻のセットを配列で保存する用

  interests        String[]
  interestThemes   Theme[]
  careerPath       String
  phone            String?
  address          String?
  purchases        Purchase[]
  mentorRequests   MentorRequest[]
  questions        Question[]
  answers          Answer[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model University {
  id        String    @id @default(cuid())
  name      String    @unique
  tags      String[]
  level     String?
  area      String?
  faculties Faculty[]
  labs      Lab[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Faculty {
  id           String       @id @default(cuid())
  name         String
  universityId String
  university   University   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  departments  Department[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([universityId, name])
}

model Department {
  id          String       @id @default(cuid())
  name        String

  facultyId   String
  faculty     Faculty      @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  themeGroups ThemeGroup[]
  exams       Exam[]
  labs        Lab[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([facultyId, name])
}

model Exam {
  id          String      @id @default(cuid())
  title       String
  price       Int
  category    String
  image       String?
  description String?
  author      String?
  contents    String[]
  preview     String?
  deptId      String?
  department  Department? @relation(fields: [deptId], references: [id], onDelete: SetNull)
  purchases   Purchase[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Purchase {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id])
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  stripeId  String?
  createdAt DateTime @default(now())
}

model Lab {
  id             String      @id @default(cuid())
  universityId   String?
  university     University? @relation(fields: [universityId], references: [id])
  universityName String?
  name           String
  tags           String[]
  heroImage      String
  website        String?
  about          String?
  profName       String?
  profImage      String?
  message        String?
  contact        Json?
  papers         Json?
  stats          Json?

  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])

  themes         Theme[]

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum MentorRequestType {
  CONSULTATION
  REVIEW
}

enum MentorRequestStatus {
  PENDING      // 申込済み・未対応
  IN_PROGRESS  // 対応中（面談日確定 / 添削中）
  DELIVERED    // 完了・引き落とし実行済み
  PAID         // 決済確認済み
  CANCELLED    // キャンセル
}

// 面談・研究計画書添削の申込
model MentorRequest {
  id                    String              @id @default(cuid())
  profileId             String
  profile               Profile             @relation(fields: [profileId], references: [id])
  type                  MentorRequestType
  status                MentorRequestStatus @default(PENDING)

  // 面談用：希望日時（例: [{date:"2024-04-15", slots:["12:00-15:00","17:00-18:00"]}]）
  preferredSlots        Json?

  // 添削用：提出書類・添削済み書類のURL（Vercel Blob）
  documentUrl           String?
  reviewedDocUrl        String?

  // 申込時のメッセージ・運営メモ
  message               String?
  adminNote             String?

  // 決済（申込時に確定した料金スナップショット）
  price                 Int
  stripeCustomerId      String?
  stripePaymentMethodId String?
  stripePaymentIntentId String?
  paidAt                DateTime?

  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
}

// 運営が変更できるサービス料金
model ServicePrice {
  id        String            @id @default(cuid())
  type      MentorRequestType @unique
  price     Int
  updatedAt DateTime          @updatedAt
}

model QaCategory {
  id        String     @id @default(cuid())
  name      String     @unique
  order     Int        @default(0)
  questions Question[]
  createdAt DateTime   @default(now())
}

model Question {
  id         String     @id @default(cuid())
  title      String
  body       String
  anonymous  Boolean    @default(false)
  categoryId String
  category   QaCategory @relation(fields: [categoryId], references: [id])
  profileId  String
  profile    Profile    @relation(fields: [profileId], references: [id])
  answers    Answer[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Answer {
  id         String   @id @default(cuid())
  body       String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ThemeGroup {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String?  @unique
  description String?

  themes      Theme[]
  departments Department[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Theme {
  id           String      @id @default(cuid())
  name         String
  slug         String?
  description  String?

  themeGroupId String
  themeGroup   ThemeGroup  @relation(fields: [themeGroupId], references: [id], onDelete: Cascade)

  labs         Lab[]
  profiles     Profile[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([themeGroupId, name])
}