// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id               String   @id // Clerk User ID
  email            String   @unique
  firstName        String
  lastName         String
  university       String   // 現在の大学
  department       String?  // 現在の学部・学科
  grade           String   // 学年
  targetUniversity String?  // 志望大学院
  targetDepartment String?  // 志望専攻
  interests       String[] // 興味のある分野（タグ）
  careerPath      String   // 希望するキャリアパス
  phone           String?
  address         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Exam {
  id          String   @id @default(cuid())
  title       String
  price       Int
  category    String
  image       String   // 画像URL
  description String?
  link        String?  // 購入・詳細リンク
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lab {
  id              String   @id @default(cuid())
  university      String
  name            String
  tags            String[]
  heroImage       String
  website         String?
  about           String?
  profName        String?
  profImage       String?
  message         String?
  contact         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
